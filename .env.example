# FlagBase Backend — environment variables (v1 scope)
# Copy this file to .env and fill in real values for local development.
#
# Note: REDIS_URL and RATE_LIMIT_PER_MINUTE are intentionally NOT included
# here. Caching and rate limiting are v2 features (see SPEC.md Section 0
# and Section 10). They'll be added back to this file when v2 work starts.

# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=changeme-generate-a-real-secret-key

# --- Database ---
DATABASE_URL=postgresql+asyncpg://flagbase:flagbase@db:5432/flagbase

# --- CORS ---
# Comma-separated list of allowed origins for the dashboard
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
